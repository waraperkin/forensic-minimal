{
  "policy": {
    "description": "Platform logs & uploads metadata — delete 60d",
    "default_state": "hot",
    "ism_template": [
      {
        "index_patterns": [
          "forensic-uploads*",
          "fp-platform-logs*",
          "forensic-alerts*"
        ],
        "priority": 90
      }
    ],
    "states": [
      {
        "name": "hot",
        "actions": [],
        "transitions": [
          {
            "state_name": "delete",
            "conditions": {
              "min_index_age": "60d"
            }
          }
        ]
      },
      {
        "name": "delete",
        "actions": [
          {
            "delete": {}
          }
        ],
        "transitions": []
      }
    ]
  }
}
