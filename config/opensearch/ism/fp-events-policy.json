{
  "policy": {
    "description": "Forensic security events — hot rollover, warm, delete 90d",
    "default_state": "hot",
    "ism_template": [
      {
        "index_patterns": [
          "forensic-windows-*",
          "forensic-linux-*",
          "forensic-web-*",
          "forensic-network-*",
          "forensic-cloud-*",
          "forensic-endpoint-*",
          "forensic-macos-*",
          "forensic-firewall-*",
          "forensic-k8s-*",
          "forensic-db-*"
        ],
        "priority": 100
      }
    ],
    "states": [
      {
        "name": "hot",
        "actions": [
          {
            "rollover": {
              "min_index_age": "7d",
              "min_primary_shard_size": "10gb"
            }
          }
        ],
        "transitions": [
          {
            "state_name": "warm",
            "conditions": {
              "min_index_age": "14d"
            }
          }
        ]
      },
      {
        "name": "warm",
        "actions": [
          {
            "replica_count": {
              "number_of_replicas": 0
            }
          }
        ],
        "transitions": [
          {
            "state_name": "delete",
            "conditions": {
              "min_index_age": "90d"
            }
          }
        ]
      },
      {
        "name": "delete",
        "actions": [
          {
            "delete": {}
          }
        ],
        "transitions": []
      }
    ]
  }
}
