{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": ["arn:aws:s3:::fp-*", "arn:aws:s3:::fp-*/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::logs-*", "arn:aws:s3:::artefacts", "arn:aws:s3:::timesketch", "arn:aws:s3:::opencti", "arn:aws:s3:::iocs"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::logs-*/*",
        "arn:aws:s3:::artefacts/*",
        "arn:aws:s3:::timesketch/*",
        "arn:aws:s3:::opencti/*",
        "arn:aws:s3:::iocs/*"
      ]
    }
  ]
}
