{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": [
        "arn:aws:s3:::fp-dfir",
        "arn:aws:s3:::fp-dfir/*",
        "arn:aws:s3:::fp-cases",
        "arn:aws:s3:::fp-cases/*",
        "arn:aws:s3:::fp-artifacts",
        "arn:aws:s3:::fp-artifacts/*",
        "arn:aws:s3:::artefacts",
        "arn:aws:s3:::artefacts/*"
      ]
    }
  ]
}
