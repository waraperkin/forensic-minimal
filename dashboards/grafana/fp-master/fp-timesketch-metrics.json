      "type": "stat",
      "title": "Sketches",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "fp-platform-health"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "fp-platform-health"
          },
          "query": "health.metric: \"sketch_count\" AND health.category: \"timesketch\"",
          "metrics": [
            {
              "id": "1",
              "type": "max",
              "field": "health.value"
            }
          ],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": {
                "interval": "1d",
                "min_doc_count": "0"
              }
            }
          ],
          "timeField": "@timestamp",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Snapshots health.value (collecte platform_health) — alignés Timesketch API / explore."
