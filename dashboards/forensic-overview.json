        "type": "grafana-opensearch-datasource",
        "uid": "fp-platform-health"
      },
      "targets": [
        {
          "refId": "h1",
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "fp-platform-health"
          },
          "query": "health.metric: \"uploads_cert\" AND health.category: \"portal\"",
          "metrics": [
            {
              "id": "1",
              "type": "max",
              "field": "health.value"
