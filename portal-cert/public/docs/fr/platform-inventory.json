{
  "version": "2026.06.06-premium++",
  "interconnections": [
    {"from": "Portail CERT/IT", "to": "MinIO + Redis", "via": "POST /api/upload", "desc": "Dépôt preuves → queue ingest"},
    {"from": "ingest-worker", "to": "OpenSearch", "via": "bulk API", "desc": "Index forensic-* / fp-*"},
    {"from": "ingest-worker", "to": "Timesketch", "via": "timesketch_io.py", "desc": "Import CSV 9 colonnes"},
    {"from": "Logstash/Filebeat", "to": "OpenSearch", "via": "pipelines ECS", "desc": "Flux réseau & logs conteneurs"},
    {"from": "OpenCTI", "to": "OpenSearch", "via": "connecteurs + ti_enrichment", "desc": "Indices fp-ti-opencti-*"},
    {"from": "MISP", "to": "OpenSearch", "via": "opensearch_ioc_misp_sync.py", "desc": "Indices fp-ti-misp-*"},
    {"from": "OpenCTI", "to": "MISP", "via": "connecteurs export/import", "desc": "Sync IOC bidirectionnelle"},
    {"from": "TheHive", "to": "Cortex", "via": "observables → analyseurs", "desc": "Enrichissement cas"},
    {"from": "cert-portal", "to": "Sekoia CP", "via": "/api/threat/sekoia/*", "desc": "Proxy :8081"},
    {"from": "cert-portal", "to": "SentinelOne CP", "via": "/api/threat/s1/*", "desc": "Proxy :8082"},
    {"from": "Sekoia fetch", "to": "Timesketch", "via": "export threat API", "desc": "Timeline investigation"},
    {"from": "Grafana", "to": "Prometheus/Loki/OS", "via": "datasources", "desc": "Métriques & logs SOC"},
    {"from": "OSD Playbooks", "to": "OpenSearch", "via": "saved searches", "desc": "77+ recherches Analyst PB"},
    {"from": "SOC Autonomous", "to": "OpenSearch + portail", "via": "soc_autonomous_master.py", "desc": "Synthèse incidents/anomalies"}
  ],
